{
    "server_host": "localhost",
    "server_port": "8080",
    "read_timeout":  5,
    "write_timeout": 10,
    "idle_timeout":  120,

    "postgres_host": "localhost",
    "postgres_port": "5034",
    
    "path_main_log": "logs/main.log",
    "level_main_log": "ERROR",
    "addsource_main_log": true,

    "path_kafka_log": "logs/kafka.log",
    "level_kafka_log": "INFO",
    "addsource_kafka_log": false,

    "path_metrics_log": "logs/metrics.log",
    "level_metrics_log": "INFO",
    "addsource_metrics_log": false,
    "enabled_kafkalog": true,
  
    "servers_kafka_log": "kafka1:9092,kafka2:9092,kafka3:9092",
    "clientID_kafka_log": "LoggerWriter",
    "acks_kafka_log": "1",
    "channelsize_kafka_log": 1000,
    "maxmessages_kafka_log": 1000
}
